<style>

    .subscription_base_top {
    margin-top: 35px;
}

  .subscription_widget_title {
    color: var(--Midnight, #272727);
    font-family: "ivypresto-headline", serif;
    font-size: 21px;
    font-style: italic;
    font-weight: 300;
    line-height: normal;
    margin-bottom: 22px;
}
.subscription_widget_01  .sw_01_subscription.subscription_base {
    position: relative;
}
.subscription_widget_01  .seller_badge {
    display: inline;
    padding: 4px 8px;
    align-items: center;
    background: var(--Midnight, #272727);
    color: var(--Classic-White, #FFF);
    font-size: 10px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    text-transform: uppercase;
    position: absolute;
    right: 10px;
    top: -23px;
}
.subscription_widget_01  input[type="radio"][name="subscription_widget_01"]{
  position: absolute;
  opacity: 0;
  pointer-events: none;
}
.subscription_widget_01  label.sw_01_subscription {
    border: 1px solid rgba(39, 39, 39, 0.10);
    display: block;
    cursor: pointer;
}
.subscription_widget_01  .check_mark{
display: none;
}
.subscription_widget_01  .subscription_head {
    display: flex;
    justify-content: space-between;
    padding: 12px;
}
.subscription_widget_01  .subscription_head_inner {
    display: flex;
    gap: 8px;
}
.subscription_widget_01  .sub__title {
    color: var(--MIDNIGHT, #272727);
    font-family: ivypresto-headline, serif;
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    line-height: normal;
}
.subscription_widget_01  .sub__discount {
    display: inline-flex;
    padding: 4px 8px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    background: var(--Red, #A50034);
    color: var(--Classic-White, #FFF);
    font-size: 10px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    text-transform: uppercase;
}
.subscription_widget_01  .sub_title_discount {
    display: flex;
    gap: 10px;
    margin-bottom: 4px;
}
.subscription_widget_01  .sub_text {
    color: var(--MIDNIGHT, #272727);
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
}
.subscription_widget_01  .sub_price_regular {
    color: rgba(39, 39, 39, 0.50);
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    text-decoration-line: line-through;
}
.subscription_widget_01  .sub_price_sale {
    color: var(--Red, #A50034);
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    margin-right: 6px;
}
.subscription_widget_01  .sub_price_per_design {
    color: var(--MIDNIGHT, #272727);
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    opacity: 0.5;
        margin-top: 4px;
}
.subscription_widget_01  .subscription_body {
    background: #F7F6F5;
    padding: 12px;
}
.subscription_widget_01  span.tick_icon {
    display: flex;
}
.subscription_widget_01  .subscription_text_item {
    display: flex;
    align-items: center;
    gap: 4px;
}
.subscription_widget_01  .subscription_text_item:not(:last-child) {
    margin-bottom: 12px;
}
.subscription_widget_01  span.tick_text {
    color: #272727;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 18.2px;
}
.subscription_widget_01  .subscription_or {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    margin: 12px 0;
}
.subscription_widget_01  .subscription_or::before,
