<script>
(function () {
  function init() {
    const forms = document.querySelectorAll('.product_form_id');
    if (!forms.length) return;

    function updateSellingPlan(value) {
      forms.forEach(form => {
        let input = form.querySelector('input[name="selling_plan"]');

        // One-time purchase
        if (value === 'one_time') {
          if (input) input.remove();
          return;
        }

        // Subscription
        if (!input) {
          input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'selling_plan';
          form.appendChild(input);
        }

        input.value = value;
      });
    }

    // Initial state
    const checked = document.querySelector(
      'input[name="subscription_widget_01"]:checked'
    );
    if (checked) updateSellingPlan(checked.value);

    // Event delegation for radio changes
    document.addEventListener('change', e => {
      if (e.target.matches('input[name="subscription_widget_01"]')) {
        updateSellingPlan(e.target.value);
      }
    });

    // Validation
    forms.forEach(form => {
      form.addEventListener('submit', e => {
        const selected = document.querySelector(
          'input[name="subscription_widget_01"]:checked'
        );

        if (!selected) {
          e.preventDefault();
          alert('Please select a purchase option.');
          return;
        }

        if (
          selected.value !== 'one_time' &&
          !form.querySelector('input[name="selling_plan"]')
        ) {
          e.preventDefault();
          alert('Subscription plan missing.');
        }
      });
    });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', init)
    : init();
})();
</script>


