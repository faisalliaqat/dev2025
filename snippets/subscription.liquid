{% if product.selling_plan_groups != blank %}
    {% assign selling_plan_group_data = product.selling_plan_groups[0] %}
    {% for selling_plan_group in product.selling_plan_groups %}
        {% if selling_plan_group.id == product.selected_or_first_available_variant.selling_plan_allocations[0].selling_plan_group_id %}
            {% assign selling_plan_group_data = selling_plan_group %}
        {% endif %}
    {% endfor %}
    
<div class="subscription_widget_01">
     

    <input 
        type="radio" 
        name="subscription_widget_01" 
        id="subscription_widget_01" 
        value="{{ selling_plan_group_data.selling_plans[0].id }}" 
        data-compare-price="{{ product.selected_or_first_available_variant.selling_plan_allocations[0].compare_at_price | money }}"
        data-price="{{ product.selected_or_first_available_variant.selling_plan_allocations[0].price | money }}"
        data-compare-price-cart="{{ product.selected_or_first_available_variant.selling_plan_allocations[0].compare_at_price }}"
        data-price-cart="{{ product.selected_or_first_available_variant.selling_plan_allocations[0].price }}"
        checked
    >
    <label for="subscription_widget_01" class="sw_01_subscription subscription_base">
        <div class="seller_badge">Bestseller</div>
       <div class="subscription_head">
        <div class="subscription_head_inner">
            <div class="subscription_icon">
                <svg class="check_mark" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M18.3327 10.0001C18.3327 5.39771 14.6017 1.66675 9.99935 1.66675C5.39697 1.66675 1.66602 5.39771 1.66602 10.0001C1.66602 14.6024 5.39697 18.3334 9.99935 18.3334C14.6017 18.3334 18.3327 14.6024 18.3327 10.0001Z" fill="#78A97C" stroke="white" stroke-width="0.833333"/>
                <path d="M6.66602 10L9.16602 12.5L13.3327 7.5" stroke="white" stroke-width="0.833333" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <svg class="uncheck_mark" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M18.3327 10.0001C18.3327 5.39771 14.6017 1.66675 9.99935 1.66675C5.39697 1.66675 1.66602 5.39771 1.66602 10.0001C1.66602 14.6024 5.39697 18.3334 9.99935 18.3334C14.6017 18.3334 18.3327 14.6024 18.3327 10.0001Z" stroke="#272727" stroke-opacity="0.1" stroke-width="0.833333"/>
                </svg>
            </div>
            {% assign compare_at_price_plan = product.selected_or_first_available_variant.selling_plan_allocations[0].compare_at_price %}
            {% assign price_plan = product.selected_or_first_available_variant.selling_plan_allocations[0].price %}
           
            <div class="subscription_title">
                <div class="sub_title_discount">
                    <span class="sub__title">Deliver Every Month</span>
                     {% if compare_at_price_plan and price_plan  and compare_at_price_plan > price_plan %}
                        {% assign discount_plan = compare_at_price_plan | minus: price_plan %}
                        {% assign percent_off_plan = discount_plan | times: 100 | divided_by: compare_at_price_plan %}
                        <span class="sub__discount">SAVE {{ percent_off_plan | round }}%</span>
                    {% endif %}
                    
                </div>
                <div class="sub_text">{{selling_plan_group_data.selling_plans[0].name}}</div>
            </div>
        </div>
        <div class="subscription_price">
            <div class="sub_price">
                <span class="sub_price_sale">{{ product.selected_or_first_available_variant.selling_plan_allocations[0].price | money }}</span>
                <span class="sub_price_regular">{{ product.selected_or_first_available_variant.selling_plan_allocations[0].compare_at_price | money }}</span>
            </div>
            {% comment %} <div class="sub_price_per_design">
                $3 / Design
            </div> {% endcomment %}
        </div>
       </div> 
       <div class="subscription_body">
        <div class="subscription_text_list">
            <div class="subscription_text_item">
                <span class="tick_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.6673 5L7.50065 14.1667L3.33398 10" stroke="#272727" stroke-width="0.833333" stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="tick_text">Seasonal colors selected by fashion experts</span>
            </div>
            <div class="subscription_text_item">
                <span class="tick_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.6673 5L7.50065 14.1667L3.33398 10" stroke="#272727" stroke-width="0.833333" stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="tick_text">Free Welcome Kit: 2-in-1 File & Remover Oil</span>
            </div>
            <div class="subscription_text_item">
                <span class="tick_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.6673 5L7.50065 14.1667L3.33398 10" stroke="#272727" stroke-width="0.833333" stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="tick_text">Pause or Cancel Anytime</span>
            </div>
            <div class="subscription_text_item">
                <span class="tick_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M16.6673 5L7.50065 14.1667L3.33398 10" stroke="#272727" stroke-width="0.833333" stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="tick_text">30 Days Money-Back-Guarantee + Free Shipping</span>
            </div>
        </div>
       </div>
    </label>

